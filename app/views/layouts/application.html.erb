<!DOCTYPE html>
<html data-bs-theme="dark">
  <head>
    <title>Farley Raffle</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <!-- iOS Web App Meta Tags -->
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Farley's Friends Raffle">
    <%= favicon_link_tag 'favicon.svg', rel: 'apple-touch-icon', type: 'image/svg+xml' %>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= favicon_link_tag 'favicon.svg' %>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="container-fluid">
      <nav class="navbar bg-body-tertiary mb-4">
        <div class="container-fluid">
          <ul class="nav nav-pills">
            <li class="nav-item navbar-brand">
              <%= link_to "Farley Raffle", pos_main_path, class: "navbar-brand" %>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-expanded="false">Events</a>
              <ul class="dropdown-menu">
                <% Event.all.each do |event| %>
                  <li>
                    <% if event == current_event %>
                      <%= link_to event.name, event, class: "dropdown-item active" %>
                    <% else %>
                      <%= link_to event.name, event, class: "dropdown-item" %>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </li>
            <li class="nav-item">
              <%= link_to "Orders", orders_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "Card Readers", readers_list_path, class: "nav-link" %>
            </li>

            <% if current_user_is_admin? %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-expanded="false">Admin</a>
                <ul class="dropdown-menu">
                  <li><%= link_to "Users", users_path, class: "dropdown-item" %></li>
                  <li><%= link_to "Roc Star Prices", roc_star_prices_path, class: "dropdown-item" %></li>
                  <li><%= link_to "POS Products", pos_products_path, class: "dropdown-item" %></li>
                </ul>
              </li>
            <% end %>
          </ul>
          <ul class="nav nav-pills">
            <% if authenticated? %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-expanded="false"><%= current_user.name %></a>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li>
                    <%= link_to "Select Event", pos_path, class: "dropdown-item" %>
                  </li>
                  <li>
                    <%= link_to "Sign out", authentication_path, data: {turbo_method: :delete, turbo_confirm: 'Are you sure?'}, method: :delete, class: "dropdown-item" %>
                  </li>
                </ul>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "Sign In", sign_in_path, class: "nav-link" %>
              </li>
            <% end %>
          </ul>
        </div>
      </nav>
      <div class="container">
        <%= yield %>
      </div>

  </body>
</html>
