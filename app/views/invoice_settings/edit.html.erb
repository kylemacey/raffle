<h1>Invoice Settings</h1>

<div class="alert alert-info">
  Select invoice payment method types to pass directly to Stripe.
  Leave the list empty to use the Stripe invoice template default.
  <%= link_to "Open Stripe invoice template settings", "https://dashboard.stripe.com/settings/billing/invoice", target: "_blank", rel: "noopener" %>
</div>

<%= form_with(model: @setting, url: invoice_setting_path, method: :patch, local: true) do |f| %>
  <% if @setting.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @setting.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :days_until_due, class: "form-label" %>
    <%= f.number_field :days_until_due, class: "form-control", min: 1, max: 365, required: true %>
  </div>

  <div class="mb-4">
    <%= f.label :payment_method_types, "Payment Method Types", class: "form-label" %>

    <input type="hidden" name="invoice_setting[payment_method_types][]" value="">

    <div class="row row-cols-1 row-cols-md-2 g-2">
      <% InvoiceSetting.payment_method_type_options.each do |label, type| %>
        <div class="col">
          <div class="form-check">
            <%= check_box_tag "invoice_setting[payment_method_types][]",
                              type,
                              @setting.payment_method_types.include?(type),
                              id: "invoice_setting_payment_method_types_#{type}",
                              class: "form-check-input" %>
            <%= label_tag "invoice_setting_payment_method_types_#{type}", label, class: "form-check-label" %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="form-text">
      Stripe validates availability by account, currency, location, and invoice state when the invoice is created.
      <%= link_to "Review payment method settings", "https://dashboard.stripe.com/settings/payment_methods", target: "_blank", rel: "noopener" %>
    </div>
  </div>

  <%= f.submit "Save settings", class: "btn btn-primary" %>
<% end %>
