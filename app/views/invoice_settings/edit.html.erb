<h1>Invoice Settings</h1>

<div class="alert alert-info">
  Stripe-hosted invoices use the enabled payment methods from the Stripe invoice template.
  The Payment Method Configuration ID is saved here for future invoice flows, but it is not sent to Stripe invoice creation.
  <%= link_to "Open Stripe invoice template settings", "https://dashboard.stripe.com/settings/billing/invoice", target: "_blank", rel: "noopener" %>
</div>

<%= form_with(model: @setting, url: invoice_setting_path, method: :patch, local: true) do |f| %>
  <% if @setting.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @setting.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :days_until_due, class: "form-label" %>
    <%= f.number_field :days_until_due, class: "form-control", min: 1, max: 365, required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :stripe_payment_method_configuration_id, "Payment Method Configuration ID", class: "form-label" %>
    <%= f.text_field :stripe_payment_method_configuration_id,
                     class: "form-control",
                     placeholder: "pmc_...",
                     autocomplete: "off" %>
    <div class="form-text">
      Optional reference ID. Current Stripe invoice creation supports invoice template defaults and explicit payment method types, not Payment Method Configuration IDs.
      <%= link_to "Manage payment method configurations", "https://dashboard.stripe.com/settings/payment_methods", target: "_blank", rel: "noopener" %>
    </div>
  </div>

  <%= f.submit "Save settings", class: "btn btn-primary" %>
<% end %>
