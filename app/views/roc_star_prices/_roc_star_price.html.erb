<div id="<%= dom_id roc_star_price %>">
  <p>
    <strong>Name:</strong>
    <%= roc_star_price.name %>
  </p>

  <p>
    <strong>Stripe Product ID:</strong>
    <%= roc_star_price.stripe_product_id %>
  </p>

  <p>
    <strong>Stripe Price ID:</strong>
    <%= roc_star_price.stripe_price_id %>
  </p>

  <p>
    <strong>Amount:</strong>
    <%= roc_star_price.amount %>
  </p>

  <p>
    <strong>Interval:</strong>
    <%= roc_star_price.interval.titleize %>
  </p>

  <p>
    <strong>Description:</strong>
    <%= roc_star_price.description %>
  </p>

</div>
