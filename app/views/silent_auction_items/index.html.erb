<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h1 class="mb-0">Silent Auction</h1>
    <p class="text-muted mb-0"><%= @event.name %></p>
  </div>
  <div class="d-flex flex-wrap gap-2 justify-content-end">
    <%= link_to "Public auction", event_public_silent_auction_path(@event), class: "btn btn-outline-secondary" %>
    <% if @items.any? %>
      <%= button_to "Open all", open_all_event_silent_auction_items_path(@event), method: :patch, class: "btn btn-success" %>
      <%= button_to "Pause all", pause_all_event_silent_auction_items_path(@event), method: :patch, class: "btn btn-warning" %>
      <%= link_to "Close all", close_all_confirmation_event_silent_auction_items_path(@event), class: "btn btn-danger" %>
    <% end %>
    <%= link_to "New item", new_event_silent_auction_item_path(@event), class: "btn btn-primary" %>
  </div>
</div>

<% if @items.any? %>
  <div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
      <thead>
        <tr>
          <th>Item</th>
          <th>Status</th>
          <th>Bids</th>
          <th>Bid state</th>
          <th>Invoice</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @items.each do |item| %>
          <tr>
            <td>
              <div class="fw-semibold"><%= item.name %></div>
              <small class="text-muted"><%= truncate(item.description, length: 90) %></small>
            </td>
            <td>
              <span class="badge <%= item.open? ? 'text-bg-success' : item.paused? ? 'text-bg-warning' : item.closed? ? 'text-bg-secondary' : 'text-bg-dark' %>">
                <%= item.status_label %>
              </span>
            </td>
            <td><%= item.bid_count %></td>
            <td>
              <div class="fw-semibold"><%= number_to_currency(item.current_bid_cents / 100.0) %></div>
              <small class="text-muted"><%= item.current_bid_label %></small>
            </td>
            <td>
              <% if item.invoice_record %>
                <span class="badge <%= item.invoice_record.last_error.present? ? 'text-bg-danger' : 'text-bg-info' %>">
                  <%= item.invoice_record.last_error.present? ? "Error" : item.invoice_record.stripe_status.presence || "Pending" %>
                </span>
              <% else %>
                <span class="text-muted">None</span>
              <% end %>
            </td>
            <td class="text-end">
              <%= link_to "View", event_silent_auction_item_path(@event, item), class: "btn btn-sm btn-outline-primary" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="text-center py-5">
    <p class="text-muted">No silent auction items have been added.</p>
    <%= link_to "New item", new_event_silent_auction_item_path(@event), class: "btn btn-primary" %>
  </div>
<% end %>

<%= link_to "Back to event", event_path(@event) %>
