<%= form_with(model: pos_product, local: true) do |f| %>
  <% if pos_product.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(pos_product.errors.count, "error") %> prohibited this product from being saved:</h2>
      <ul>
        <% pos_product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, class: 'form-label' %>
    <%= f.text_field :name, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :formatted_price, 'Price', class: 'form-label' %>
    <div class="input-group">
      <span class="input-group-text">$</span>
      <%= f.text_field :formatted_price,
                       class: 'form-control',
                       value: (number_with_precision(f.object.formatted_price, precision: 2) || 0) %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :product_type, 'Product Type (Optional)', class: 'form-label' %>
    <%= f.select :product_type,
                 options_for_select([['(none)', '']] + PosProducts::Factory.human_readable_types.map { |k, v| [v, k] }, pos_product.product_type),
                 {},
                 class: 'form-select',
                 data: {
                   controller: "pos-product-form",
                   action: "change->pos-product-form#loadConfigurationFields",
                   url: configuration_fields_pos_products_path
                 } %>
  </div>

  <div id="configuration-fields">
    <%= render 'configuration_fields', schema: [] %>
  </div>

  <div class="mb-3">
    <%= f.label :active, class: 'form-label' %>
    <%= f.check_box :active %>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: 'form-label' %>
    <%= f.text_area :description, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :stripe_product_id, class: 'form-label' %>
    <%= f.text_field :stripe_product_id, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :stripe_price_id, class: 'form-label' %>
    <%= f.text_field :stripe_price_id, class: 'form-control' %>
  </div>

  <div class="actions">
    <%= f.submit class: 'btn btn-success' %>
  </div>
<% end %>