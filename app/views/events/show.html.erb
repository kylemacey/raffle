<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-0"><%= @event.name %></h1>
    <small class="text-muted">Event Dashboard</small>
  </div>
  <% if current_user_can?("events.manage") %>
    <%= link_to 'Edit Event', edit_event_path(@event), class: 'btn btn-outline-secondary' %>
  <% end %>
</div>

<div class="row">
  <!-- Left Column: Stats & Drawings -->
  <div class="col-md-8">
    <% if @show_event_financials %>
      <!-- Stats Cards -->
      <div class="card mb-4">
      <div class="card-header">
        <h5 class="card-title mb-0">At a Glance</h5>
      </div>
      <div class="card-body">
        <div class="row text-center">
          <div class="col">
            <div class="h3"><%= number_to_currency(@stats[:gross_volume] / 100.0) %></div>
            <div class="text-muted">Gross Volume</div>
          </div>
          <div class="col">
            <div class="h3"><%= number_with_delimiter(@stats[:total_orders]) %></div>
            <div class="text-muted">Completed Orders</div>
          </div>
          <div class="col">
            <div class="h3"><%= number_with_delimiter(@stats[:total_entries]) %></div>
            <div class="text-muted">Total Entries</div>
          </div>
        </div>
      </div>
    </div>
    <% end %>

    <% if current_user_can?("drawings.manage") %>
      <!-- Drawings List -->
      <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0">Drawings</h5>
      </div>
      <div class="card-body">
        <% if @drawings.any? %>
          <div class="table-responsive">
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>Drawing Name/Slug</th>
                  <th>Winners</th>
                  <th>Created</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @drawings.each do |drawing| %>
                  <tr>
                    <td><%= link_to drawing.slug, event_drawing_path(@event, drawing) %></td>
                    <td><span class="badge bg-secondary"><%= drawing.winners.count %></span></td>
                    <td><%= time_ago_in_words(drawing.created_at) %> ago</td>
                    <td>
                      <%= link_to 'View', event_drawing_path(@event, drawing), class: 'btn btn-sm btn-outline-primary' %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="text-center py-4">
            <p class="text-muted">No drawings have been performed for this event yet.</p>
            <%= link_to 'Start a New Drawing', new_event_drawing_path(@event), class: 'btn btn-primary' %>
          </div>
        <% end %>
      </div>
    </div>
    <% end %>
  </div>

  <!-- Right Column: Actions -->
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0">Actions</h5>
      </div>
      <div class="card-body">
        <div class="d-grid gap-2">
          <% if current_user_can?("pos.sell") %>
            <%= link_to 'Go to POS for this Event', pos_main_path, class: 'btn btn-success' %>
          <% end %>
          <% if current_user_can?("drawings.manage") %>
            <%= link_to 'New Drawing', new_event_drawing_path(@event), class: 'btn btn-primary' %>
          <% end %>
          <% if current_user_can?("entries.manage") %>
            <%= link_to 'View Entries', event_entries_path(@event), class: 'btn btn-outline-secondary' %>
          <% end %>
          <% if current_user_can_any?("orders.view_all", "orders.view_event", "orders.view_own") %>
            <%= link_to 'View Orders', orders_path, class: 'btn btn-outline-secondary' %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Heavy Hitters -->
    <% if @show_supporter_details %>
      <div class="card mt-4">
      <div class="card-header">
        <h5 class="card-title mb-0">Raffle Heavy Hitters</h5>
      </div>
      <div class="card-body">
        <% if @heavy_hitters.any? %>
          <ul class="list-group list-group-flush">
            <% @heavy_hitters.each do |hitter| %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span class="text-truncate" title="<%= hitter[:name] %>">
                  <%= hitter[:name] %>
                </span>
                <span class="badge bg-primary rounded-pill">
                  <%= hitter[:qty] %> (<%= hitter[:percentage] %>%)
                </span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted text-center">No entries yet to determine heavy hitters.</p>
        <% end %>
      </div>
    </div>
    <% end %>
  </div>
</div>

<div>
  <%= link_to "Back to events", events_path %>

  <% if current_user_can?("events.manage") %>
    <%= button_to "Destroy this event", @event, method: :delete %>
  <% end %>
</div>
