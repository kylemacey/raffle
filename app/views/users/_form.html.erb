<%= form_with(model: user) do |form| %>
  <% if user.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(user.errors.count, "error") %> prohibited this user from being saved:</h2>

      <ul>
        <% user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :pin, style: "display: block" %>
    <%= form.text_field :pin %>
  </div>

  <% if current_user_can?("roles.assign") %>
    <fieldset>
      <legend>Roles</legend>

      <% @roles.each do |role| %>
        <div class="card mb-3">
          <div class="card-body">
            <div class="form-check">
              <%= check_box_tag "user[role_ids][]", role.id, user.role_ids.include?(role.id), id: "user_role_ids_#{role.id}", class: "form-check-input" %>
              <%= label_tag "user_role_ids_#{role.id}", role.name, class: "form-check-label fw-semibold" %>
              <span class="badge text-bg-secondary ms-2"><%= pluralize(role.capability_badges.length, "capability") %></span>
            </div>

            <p class="mb-2 text-body-secondary">
            <%= role.description %>
            </p>

            <div class="d-flex flex-wrap gap-1">
              <% role.capability_badges.each do |badge| %>
                <span class="badge rounded-pill <%= badge[:css_class] %>"><%= badge[:label] %></span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <% if user.has_role?("platform_admin") && !current_user_can?("super_admin.assign") %>
        <div class="card mb-3">
          <div class="card-body">
            <div class="form-check">
              <%= check_box_tag "platform_admin_locked", "1", true, disabled: true, class: "form-check-input" %>
              <%= label_tag "platform_admin_locked", "SuperAdmin", class: "form-check-label fw-semibold" %>
              <span class="badge text-bg-secondary ms-2">locked</span>
            </div>
            <p class="mb-0 text-body-secondary">
              SuperAdmin assignment requires platform-level permission.
            </p>
          </div>
        </div>
      <% end %>

      <%= hidden_field_tag "user[role_ids][]", "" %>
    </fieldset>
  <% end %>

  <% if user.roles.any? %>
    <div>
      <strong>Effective capabilities:</strong>
      <div class="d-flex flex-wrap gap-1 mt-2">
        <% user.capability_badges.each do |badge| %>
          <span class="badge rounded-pill <%= badge[:css_class] %>"><%= badge[:label] %></span>
        <% end %>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.submit %>
  </div>
<% end %>
