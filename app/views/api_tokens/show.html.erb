<p style="color: green"><%= notice %></p>

<div class="d-flex align-items-center justify-content-between mb-3">
  <h1><%= @api_token.name %></h1>
  <%= link_to "Back to API tokens", api_tokens_path, class: "btn btn-secondary" %>
</div>

<% if @plain_token.present? %>
  <div class="alert alert-warning">
    <h2 class="h5">Copy this token now</h2>
    <p>This API token will not be shown again.</p>
    <input class="form-control font-monospace" readonly value="<%= @plain_token %>">
  </div>
<% end %>

<dl class="row">
  <dt class="col-sm-3">Token</dt>
  <dd class="col-sm-9"><code><%= @api_token.masked_token %></code></dd>

  <dt class="col-sm-3">Status</dt>
  <dd class="col-sm-9">
    <% if @api_token.active? %>
      <span class="badge text-bg-success">Active</span>
    <% else %>
      <span class="badge text-bg-secondary">Expired</span>
    <% end %>
  </dd>

  <dt class="col-sm-3">Expires</dt>
  <dd class="col-sm-9"><%= @api_token.expires_at ? l(@api_token.expires_at, format: :long) : "Never" %></dd>

  <dt class="col-sm-3">Created by</dt>
  <dd class="col-sm-9"><%= @api_token.created_by.name %></dd>

  <dt class="col-sm-3">Created</dt>
  <dd class="col-sm-9"><%= l(@api_token.created_at, format: :long) %></dd>
</dl>

<%= button_to "Delete API token", api_token_path(@api_token), method: :delete, data: { turbo_confirm: "Delete this API token?" }, class: "btn btn-danger" %>
