<div class="auction-header">
  <div>
    <h1>Silent Auction</h1>
    <p class="auction-header-subtitle"><%= pluralize(@items.size, "item") %> available</p>
  </div>
</div>

<% if @items.any? %>
  <div class="auction-grid">
    <% @items.each do |item| %>
      <%= link_to event_public_silent_auction_item_path(@event, item), class: "auction-item-card" do %>
        <div class="auction-item-image-wrap">
          <%= image_tag item.image_url, alt: item.name, class: "auction-item-image" %>
          <span class="auction-status auction-status-<%= item.status %>"><%= item.status_label %></span>
        </div>
        <div class="auction-item-body">
          <h2><%= item.name %></h2>
          <p><%= truncate(item.description, length: 130) %></p>
          <div class="auction-item-meta">
            <div>
              <span><%= item.current_bid_label %></span>
              <strong><%= number_to_currency(item.current_bid_cents / 100.0) %></strong>
            </div>
            <div class="text-end">
              <span>Bids</span>
              <strong><%= item.bid_count %></strong>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="auction-empty">
    <h2>No auction items are available.</h2>
  </div>
<% end %>
