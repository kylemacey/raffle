<% terminal_intent = local_assigns[:terminal_intent] || payment_intent %>
<% if terminal_intent.status == 'succeeded' || terminal_intent.status == 'requires_capture' %>
  <div class="alert alert-success">
    <h4 class="alert-heading">Transaction Successful!</h4>
    <p>Your transaction has been processed successfully.</p>
    <p>Redirecting to the success page...</p>
  </div>

  <%# This meta tag will trigger a client-side redirect after a short delay %>
  <%= tag.meta "http-equiv": "refresh", content: "2;url=#{pos_success_path(order_id)}" %>

<% else %>
  <div class="alert alert-danger">
    <h4 class="alert-heading">Transaction Failed</h4>
    <p>There was an issue processing the transaction. The status is: <strong><%= terminal_intent.status %></strong>.</p>
    <%= link_to "Return to POS", pos_main_path, class: "btn btn-primary" %>
  </div>
<% end %>
