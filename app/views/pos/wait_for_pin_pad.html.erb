<div data-controller="redirect">
  <h1><%= @setup_intent ? "Subscription Setup" : "Payment Processing" %></h1>

  <%= turbo_stream_from "payment_status_#{@terminal_intent.id}" %>
  <div id="redirect_target" hidden></div>

  <turbo-frame id="payment_status_<%= @terminal_intent.id %>">
    Complete the <%= @setup_intent ? "subscription setup" : "transaction" %> on the reader <em><%= current_reader.label %></em>.
  </turbo-frame>

  <% if Rails.env.development? && current_reader&.device_type&.start_with?('simulated') %>
    <div class="card my-4">
      <div class="card-header">
        <h5 class="card-title mb-0">Simulated Reader Controls (Development)</h5>
      </div>
      <div class="card-body">
        <div id="simulation_controls">
          <p><strong><%= @setup_intent ? "Setup Intent" : "Payment Intent" %>:</strong> <code><%= @terminal_intent.id %></code></p>
          <% if @payment_intent %>
            <p><strong>Amount:</strong> <%= number_to_currency(@payment_intent.amount / 100.0) %></p>
          <% else %>
            <p><strong>Terminal Charge:</strong> <%= number_to_currency(0) %></p>
          <% end %>
          <div class="d-grid gap-2">
            <%= form_with(url: simulate_payment_path(@terminal_intent.id), method: :post) do |form| %>
              <%= form.submit "Simulate Successful Card", class: "btn btn-success" %>
            <% end %>
            <%= form_with(url: simulate_decline_path(@terminal_intent.id), method: :post) do |form| %>
              <%= form.submit "Simulate Declined Card", class: "btn btn-warning" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <hr>
  <p><%= button_to "Cancel Payment", readers_cancel_action_path, method: :delete, class: "btn btn-danger" %></p>
</div>
