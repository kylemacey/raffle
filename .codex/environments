name = "Raffle"

[setup]
script = ""

[[actions]]
name = "Run App"
icon = "run"
command = '''
export PATH="$HOME/.rbenv/bin:$PATH"
eval "$(rbenv init - zsh)"
export DATABASE_URL='postgres://postgres:password@127.0.0.1:55434/raffle_development'
export PORT=3030
STRIPE_FORWARD_URL="http://127.0.0.1:${PORT}/webhooks/stripe"
STRIPE_LOG="$(mktemp -t raffle-stripe-listen.XXXXXX.log)"

cleanup() {
  if [ -n "${TAIL_PID:-}" ] && kill -0 "$TAIL_PID" 2>/dev/null; then kill "$TAIL_PID" 2>/dev/null || true; fi
  if [ -n "${STRIPE_PID:-}" ] && kill -0 "$STRIPE_PID" 2>/dev/null; then kill "$STRIPE_PID" 2>/dev/null || true; fi
  rm -f "$STRIPE_LOG"
}

trap cleanup EXIT INT TERM

stripe listen --skip-update --color off --forward-to "$STRIPE_FORWARD_URL" >"$STRIPE_LOG" 2>&1 &
STRIPE_PID=$!

tail -n +1 -f "$STRIPE_LOG" >&2 &
TAIL_PID=$!

while :; do
  if ! kill -0 "$STRIPE_PID" 2>/dev/null; then
    cat "$STRIPE_LOG" >&2
    exit 1
  fi

  STRIPE_ENDPOINT_SECRET="$(sed -nE 's/.*secret is (whsec_[A-Za-z0-9]+).*/\1/p' "$STRIPE_LOG" | head -n1)"
  if [ -n "$STRIPE_ENDPOINT_SECRET" ]; then
    export STRIPE_ENDPOINT_SECRET
    echo "Using Stripe webhook secret: $STRIPE_ENDPOINT_SECRET"
    break
  fi

  sleep 0.2
done

bundle exec rails server -b 127.0.0.1
