#!/usr/bin/env sh
set -eu

cd "$(dirname "$0")/.."

if [ -x bin/rackmount-env ]; then
  eval "$(bin/rackmount-env)"
fi

: "${RAILS_ENV:=development}"
: "${WEB_PORT:=3000}"

stripe_api_key="${STRIPE_API_KEY:-${STRIPE_SECRET_KEY:-}}"
if [ -n "${STRIPE_API_KEY:-}" ]; then
  stripe_api_key_source="STRIPE_API_KEY"
else
  stripe_api_key_source="STRIPE_SECRET_KEY"
fi

validate_staging_stripe_key() {
  key_name="$1"
  key_value="$2"

  case "$key_value" in
    sk_test_*|rk_test_*)
      ;;
    sk_live_*|rk_live_*)
      echo "RAILS_ENV=staging must use Stripe test-mode credentials; ${key_name} is a live-mode key." >&2
      exit 78
      ;;
    *)
      echo "RAILS_ENV=staging requires ${key_name} to be a Stripe test-mode secret key (sk_test_...) or restricted key (rk_test_...)." >&2
      exit 78
      ;;
  esac
}

if [ "$RAILS_ENV" = "staging" ]; then
  staging_stripe_key_count=0

  if [ -n "${STRIPE_SECRET_KEY:-}" ]; then
    staging_stripe_key_count=$((staging_stripe_key_count + 1))
    validate_staging_stripe_key "STRIPE_SECRET_KEY" "$STRIPE_SECRET_KEY"
  fi

  if [ -n "${STRIPE_API_KEY:-}" ]; then
    staging_stripe_key_count=$((staging_stripe_key_count + 1))
    validate_staging_stripe_key "STRIPE_API_KEY" "$STRIPE_API_KEY"
  fi

  if [ "$staging_stripe_key_count" -eq 0 ]; then
    echo "RAILS_ENV=staging requires STRIPE_SECRET_KEY or STRIPE_API_KEY set to a Stripe test-mode secret key (sk_test_...) or restricted key (rk_test_...)." >&2
    exit 78
  fi
fi

if [ -z "$stripe_api_key" ]; then
  echo "STRIPE_API_KEY or STRIPE_SECRET_KEY is required for Rackmount Stripe webhook forwarding." >&2
  echo "Set one in this project's .env so the Stripe CLI does not use another configured project." >&2
  exit 78
fi

if ! command -v stripe >/dev/null 2>&1; then
  echo "stripe CLI is required for webhook forwarding but was not found in PATH." >&2
  exit 127
fi

forward_to="${STRIPE_WEBHOOK_FORWARD_TO:-http://127.0.0.1:${WEB_PORT}/webhooks/stripe}"
default_events="terminal.reader.action_succeeded,terminal.reader.action_failed,invoice.finalized,invoice.sent,invoice.paid,invoice.payment_failed,invoice.finalization_failed,invoice.voided"
events="${STRIPE_WEBHOOK_EVENTS:-$default_events}"

echo "Forwarding Stripe webhooks to ${forward_to}"
echo "Using Stripe API key from ${stripe_api_key_source}"
echo "Forwarding Stripe events: ${events}"

exec stripe listen \
  --api-key "$stripe_api_key" \
  --skip-update \
  --color off \
  --events "$events" \
  --forward-to "$forward_to"
