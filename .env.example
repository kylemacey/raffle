# Stripe account used by Rails and by the Rackmount Stripe CLI service.
# For a single local account these can usually be the same test secret key.
STRIPE_API_KEY=sk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key

# Optional. Rackmount refreshes this from STRIPE_API_KEY by default before
# starting Rails. Set RACKMOUNT_STRIPE_SYNC_ENDPOINT_SECRET=0 to use this value
# exactly as written.
# STRIPE_ENDPOINT_SECRET=whsec_your_secret

# Rackmount forwards the webhook types currently handled by the app.
# STRIPE_WEBHOOK_EVENTS=terminal.reader.action_succeeded,terminal.reader.action_failed,invoice.finalized,invoice.sent,invoice.paid,invoice.payment_failed,invoice.finalization_failed,invoice.voided
# STRIPE_WEBHOOK_FORWARD_TO=http://127.0.0.1:3000/webhooks/stripe

# Host-based Rackmount development database. This default matches the
# docker-compose.yml db service published on the host.
DATABASE_URL=postgres://postgres:password@127.0.0.1:55434/raffle_development

# GoodJob worker process settings. Rackmount exports these to the worker when
# present; the defaults process every queue with five worker threads.
# GOOD_JOB_QUEUES=*
# GOOD_JOB_MAX_THREADS=5
# GOOD_JOB_POLL_INTERVAL=10
# GOOD_JOB_SHUTDOWN_TIMEOUT=30

# Staging example. Use staging-only infrastructure and Stripe test-mode keys.
# RAILS_ENV=staging
# SECRET_KEY_BASE=your_staging_secret_key_base
# DATABASE_URL=postgres://postgres:password@127.0.0.1:55434/raffle_staging
# REDIS_URL=redis://localhost:6379/2
# STRIPE_API_KEY=sk_test_your_staging_key
# STRIPE_SECRET_KEY=sk_test_your_staging_key
# STRIPE_ENDPOINT_SECRET=whsec_your_staging_secret
